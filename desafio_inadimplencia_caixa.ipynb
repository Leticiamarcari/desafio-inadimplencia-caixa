   "metadata": {},
   "source": [
    "\n",
    "# Desafio CAIXA — Análise de Inadimplência Habitacional\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "226b64df",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import statsmodels.api as sm\n",
    "\n",
    "from statsmodels.tsa.holtwinters import ExponentialSmoothing\n",
    "\n",
    "pd.set_option('display.max_columns', None)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "531573af",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "arquivo = 'desafio_inadimplencia_caixa.xlsx'\n",
    "\n",
    "contratos = pd.read_excel(arquivo, sheet_name='contratos')\n",
    "parcelas = pd.read_excel(arquivo, sheet_name='parcelas')\n",
    "macro = pd.read_excel(arquivo, sheet_name='indicadores_macro')\n",
    "\n",
    "print('Contratos:', contratos.shape)\n",
    "print('Parcelas:', parcelas.shape)\n",
    "print('Macro:', macro.shape)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0275f3ba",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "inad = (\n",
    "    parcelas.groupby('id_contrato')['fl_inadimplente']\n",
    "    .max()\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "inad.columns = ['id_contrato', 'inadimplente']\n",
    "\n",
    "base = contratos.merge(inad, on='id_contrato')\n",
    "\n",
    "base.head()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "e6f2410b",
   "metadata": {},
   "source": [
    "\n",
    "# Análise Exploratória\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "914db86a",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "base.groupby(\n",
    "    pd.qcut(base['score_credito_contratacao'], 5)\n",
    ")['inadimplente'].mean().plot(kind='bar', figsize=(8,4))\n",
    "\n",
    "plt.title('Inadimplência por Faixa de Score')\n",
    "plt.ylabel('Taxa')\n",
    "\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4d94c61f",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "base.groupby(\n",
    "    pd.qcut(base['ltv'], 5)\n",
    ")['inadimplente'].mean().plot(kind='bar', figsize=(8,4))\n",
    "\n",
    "plt.title('Inadimplência por Faixa de LTV')\n",
    "plt.ylabel('Taxa')\n",
    "\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "aafb5523",
   "metadata": {},
   "source": [
    "\n",
    "# Regressão Logística\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5cdd5f7d",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "dados = base[\n",
    "    [\n",
    "        'inadimplente',\n",
    "        'tx_juros_anual',\n",
    "        'score_credito_contratacao',\n",
    "        'ltv',\n",
    "        'prazo_meses',\n",
    "        'faixa_renda',\n",
    "        'programa_social'\n",
    "    ]\n",
    "]\n",
    "\n",
    "dados = pd.get_dummies(dados, drop_first=True)\n",
    "\n",
    "for c in dados.columns:\n",
    "    dados[c] = pd.to_numeric(dados[c], errors='coerce')\n",
    "\n",
    "dados = dados.dropna()\n",
    "\n",
    "y = dados['inadimplente'].astype(float)\n",
    "\n",
    "X = dados.drop(columns=['inadimplente']).astype(float)\n",
    "\n",
    "X = sm.add_constant(X)\n",
    "\n",
    "modelo = sm.Logit(y, X).fit()\n",
    "\n",
    "print(modelo.summary())\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "a3a66778",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "odds = pd.DataFrame({\n",
    "    'Variavel': modelo.params.index,\n",
    "    'Odds_Ratio': np.exp(modelo.params.values),\n",
    "    'P_Valor': modelo.pvalues.values\n",
    "})\n",
    "\n",
    "odds.sort_values('P_Valor').head(15)\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "136de5b9",
   "metadata": {},
   "source": [
    "\n",
    "# Série Temporal\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "5aca3e33",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "parcelas['dt_referencia'] = pd.to_datetime(parcelas['dt_referencia'])\n",
    "\n",
    "serie = (\n",
    "    parcelas.groupby('dt_referencia')['fl_inadimplente']\n",
    "    .mean()\n",
    "    .sort_index()\n",
    ")\n",
    "\n",
    "serie.plot(figsize=(12,5))\n",
    "\n",
    "plt.title('Taxa Mensal de Inadimplência')\n",
    "\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "b83817cd",
   "metadata": {},
   "source": [
    "\n",
    "# Forecast — Próximos 6 Meses\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "43abb22a",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "modelo_ts = ExponentialSmoothing(\n",
    "    serie,\n",
    "    trend='add',\n",
    "    seasonal='add',\n",
    "    seasonal_periods=12\n",
    ").fit()\n",
    "\n",
    "forecast = modelo_ts.forecast(6)\n",
    "\n",
    "forecast\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "b7d3ae2b",
   "metadata": {},
   "outputs": [],
   "source": [
    "\n",
    "serie.plot(figsize=(12,5), label='Histórico')\n",
    "\n",
    "forecast.plot(label='Forecast')\n",
    "\n",
    "plt.legend()\n",
    "\n",
    "plt.title('Previsão da Inadimplência')\n",
    "\n",
    "plt.show()\n"
   ]
  },
 ],
